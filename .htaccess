# EASEO CMS — Root .htaccess
# Security, routing, caching, URL rewrites

# Prevent directory listing
Options -Indexes

# Prevent access to sensitive files
<FilesMatch "\.(json|log|md)$">
    Require all denied
</FilesMatch>

# Block access to data directory (belt and suspenders)
<IfModule mod_rewrite.c>
    RewriteEngine On

    # Force HTTPS (uncomment in production)
    # RewriteCond %{HTTPS} off
    # RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

    # Remove trailing slash (except directories)
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteRule ^(.*)/$ /$1 [L,R=301]

    # Sitemap
    RewriteRule ^sitemap\.xml$ sitemap.php [L]

    # RSS Feed
    RewriteRule ^feed/?$ feed.php [L]

    # Blog routes
    RewriteRule ^blog/?$ blog.php [L,QSA]
    RewriteRule ^blog/categorie/([^/]+)/?$ blog.php?categorie=$1 [L,QSA]
    RewriteRule ^blog/pagina/([0-9]+)/?$ blog.php?pagina=$1 [L,QSA]
    RewriteRule ^blog/([^/]+)/?$ blog-post.php?slug=$1 [L]

    # Legal pages
    RewriteRule ^privacyverklaring/?$ privacyverklaring.php [L]
    RewriteRule ^voorwaarden/?$ voorwaarden.php [L]
    RewriteRule ^cookiebeleid/?$ cookiebeleid.php [L]

    # Contact
    RewriteRule ^contact/?$ contact.php [L]

    # Dynamic pages from pages.json (parent/child support)
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteRule ^([a-z0-9-]+)/([a-z0-9-]+)/?$ pagina-router.php?slug=$1/$2 [L,QSA]

    # Dynamic pages (catch-all — must be last)
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteRule ^([a-z0-9-]+)/?$ pagina-router.php?slug=$1 [L,QSA]
</IfModule>

# Security headers
<IfModule mod_headers.c>
    Header always set X-Content-Type-Options "nosniff"
    Header always set X-Frame-Options "SAMEORIGIN"
    Header always set X-XSS-Protection "1; mode=block"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>

# Caching
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType image/jpeg "access plus 1 year"
    ExpiresByType image/png "access plus 1 year"
    ExpiresByType image/webp "access plus 1 year"
    ExpiresByType image/svg+xml "access plus 1 year"
    ExpiresByType text/css "access plus 1 month"
    ExpiresByType application/javascript "access plus 1 month"
</IfModule>

# Gzip compression
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/css application/javascript application/json text/xml
</IfModule>
